OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
NEWSAPI_KEY=
SEC_USER_AGENT=deep-research-agent/0.2 your_email@example.com
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/deep_research_agent
RESET_DATABASE_ON_STARTUP=false
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=investment_jobs
EVENT_CHANNEL_PREFIX=investment_job_events
REQUEST_TIMEOUT=20
AGENT_MAX_STEPS=4
AGENT_TIMEOUT_SECONDS=45
PRICE_LOOKBACK_DAYS=90
NEWS_DAYS=14
MAX_NEWS_ARTICLES=20
MAX_WEBSITE_PAGES=4
WEBSITE_PAGE_CHAR_LIMIT=6000
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
FILING_MAX_DOCUMENTS=4
FILING_EVIDENCE_LIMIT=8
RECENT_DAYS_THRESHOLD=120
MINIMUM_EVIDENCE_CARDS=4
FINAL_EVIDENCE_LIMIT=12
RETRIEVAL_TOP_K=8
BLOCKING_ANALYZE_TIMEOUT_SECONDS=90
WORKER_POLL_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO
